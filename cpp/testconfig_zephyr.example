# Periph Zephyr test configuration
# Copy this file to testconfig and fill in your values.
# testconfig is gitignored — never commit it.

# ------------------------------------------------------------------
# Board
# ------------------------------------------------------------------
# Zephyr board identifier (passed to west build -b)
# Examples:
#   nrf52840dk/nrf52840
#   rpi_pico
#   nucleo_f401re
ZEPHYR_BOARD=

# Serial port for reading test output
ZEPHYR_PORT=/dev/ttyACM0

# ------------------------------------------------------------------
# I²C
# ------------------------------------------------------------------
# I²C address of the device under test (hex)
I2C_ADDR=0x40

# ------------------------------------------------------------------
# Test timeouts
# ------------------------------------------------------------------
SERIAL_TIMEOUT=20
