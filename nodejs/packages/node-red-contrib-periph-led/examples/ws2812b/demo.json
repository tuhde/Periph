    "repeat": "2",
    "payload": "{\"r\":0,\"g\":255,\"b\":0}",
    "payloadType": "json",
    "wires": [["ws2812b-node"]]
  },
  {
    "id": "inject-blue",
    "type": "inject",
    "z": "ws2812b-demo-tab",
    "name": "Blue",
    "props": [{ "p": "payload" }],
    "repeat": "2",
    "payload": "{\"r\":0,\"g\":0,\"b\":255}",
