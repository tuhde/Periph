    "z": "ws2812b-demo-tab",
    "name": "Orange",
    "props": [{ "p": "payload" }],
    "repeat": "2",
    "payload": "{\"r\":255,\"g\":80,\"b\":0}",
    "payloadType": "json",
    "wires": [["ws2812b-node"]]
  },
  {
    "id": "inject-yellow",
