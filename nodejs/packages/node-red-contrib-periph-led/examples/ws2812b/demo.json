    "name": "Yellow",
    "props": [{ "p": "payload" }],
    "repeat": "2",
    "payload": "{\"r\":255,\"g\":200,\"b\":0}",
    "payloadType": "json",
    "wires": [["ws2812b-node"]]
  },
  {
    "id": "inject-green",
    "type": "inject",
