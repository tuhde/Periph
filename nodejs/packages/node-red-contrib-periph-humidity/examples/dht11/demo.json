[
    {
        "id": "tab-dht11-demo",
        "type": "tab",
        "label": "DHT11 Indoor Comfort",
        "disabled": false,
        "info": "Indoor comfort monitor: an inject node fires every 5 seconds and triggers a periph-dht11 read. The output connects to a debug node (logging the full payload) and two dashboard gauge nodes (node-red-dashboard) for temperature in °C and humidity in %RH. The driver retries the read up to 3 times on checksum or timeout errors, so a single dropped bit does not abort the loop."
    },
    {
        "id": "inj-tick",
        "type": "inject",
        "name": "every 5 s",
        "repeat": "5",
        "crontab": "",
        "once": true,
        "onceDelay": 0.1,
        "topic": "",
        "payload": "",
        "payloadType": "date",
        "z": "tab-dht11-demo",
        "x": 130,
        "y": 120,
        "wires": [["dht-read"]]
    },
    {
        "id": "dht-read",
        "type": "periph-dht11",
        "name": "Read DHT11",
        "dataPin": "4",
        "retries": "3",
        "z": "tab-dht11-demo",
        "x": 320,
        "y": 120,
        "wires": [["dbg-dht", "gauge-temp", "gauge-hum"]]
    },
    {
        "id": "dbg-dht",
        "type": "debug",
        "name": "DHT11",
        "active": true,
        "tosidebar": true,
        "console": false,
        "tostatus": true,
        "complete": "payload",
        "targetType": "msg",
        "statusVal": "payload.temperature_c",
        "statusType": "auto",
        "z": "tab-dht11-demo",
        "x": 520,
        "y": 60,
        "wires": []
    },
    {
        "id": "gauge-temp",
        "type": "ui_gauge",
        "name": "Temperature",
        "group": "grp-indoor",
        "order": 1,
        "width": 6,
        "height": 4,
        "gtype": "gage",
        "title": "Temperature",
        "label": "°C",
        "min": "-20",
        "max": "60",
        "colors": ["#1e90ff", "#00b7eb", "#ca3838"],
        "x": 540,
        "y": 120,
        "wires": []
    },
    {
        "id": "gauge-hum",
        "type": "ui_gauge",
        "name": "Humidity",
        "group": "grp-indoor",
        "order": 2,
        "width": 6,
        "height": 4,
        "gtype": "gage",
        "title": "Humidity",
        "label": "%RH",
        "min": "0",
        "max": "100",
        "colors": ["#ca3838", "#00b7eb", "#1e90ff"],
        "x": 540,
        "y": 180,
        "wires": []
    },
    {
        "id": "grp-indoor",
        "type": "ui_group",
        "name": "Indoor",
        "tab": "tab-dash",
        "order": 1,
        "disp": true,
        "width": "12"
    },
    {
        "id": "tab-dash",
        "type": "ui_tab",
        "name": "Indoor",
        "icon": "dashboard",
        "order": 1
    }
]
