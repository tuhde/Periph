[
    {
        "id": "bme680-device-1",
        "type": "bme680-device",
        "name": "BME680 @ i2c-1",
        "bus": "1",
        "addr": "0x76",
        "osrsT": "1",
        "osrsP": "1",
        "osrsH": "1",
        "filter": "0",
        "heaterTemp": "320",
        "heaterDur": "150"
    },
    {
        "id": "bme680-read-1",
        "type": "periph-bme680",
        "name": "BME680 Air Quality",
        "device": "bme680-device-1",
        "seaLevelHpa": "1013.25",
        "wires": [["debug-1", "chart-temp-1", "chart-pres-1", "chart-hum-1", "chart-gas-1", "chart-alt-1", "chart-dew-1"]]
    },
    {
        "id": "inject-timer-1",
        "type": "inject",
        "name": "Every 10 seconds",
        "topic": "",
        "payload": "",
        "payloadType": "date",
        "repeat": "10",
        "crontab": "",
        "onceDelay": "0.1",
        "wires": [["bme680-read-1"]]
    },
    {
        "id": "debug-1",
        "type": "debug",
        "name": "Debug output",
        "active": true,
        "tosideuit": false,
        "console": "false",
        "tostatus": "false",
