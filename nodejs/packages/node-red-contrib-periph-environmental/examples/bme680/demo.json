        "x": 480,
        "y": 320,
        "wires": []
    },
    {
        "id": "chart-hum-1",
        "type": "ui_chart",
        "name": "Humidity",
        "group": "bme680-group-1",
        "order": 3,
        "width": 6,
        "height": 4,
        "label": "Humidity (%RH)",
